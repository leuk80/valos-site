---
const currentYear = new Date().getFullYear();
---

<footer class="py-10 border-t border-white/5 bg-navy-950">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <svg width="24" height="24" viewBox="0 0 32 32" class="flex-shrink-0">
          <rect width="32" height="32" rx="5" fill="#3B7EF7"/>
          <path d="M8 9l8 14 8-14" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <span class="text-xs font-medium tracking-[0.08em] text-slate-600 group-hover:text-slate-400 transition-colors">
          Valos Group
        </span>
      </a>

      <!-- Links + Copyright -->
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-slate-700">
        <a href="/impressum" class="hover:text-slate-400 transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-slate-400 transition-colors">Datenschutz</a>
        <span class="text-slate-800">© {currentYear} Valos Group</span>
      </div>

    </div>
  </div>
</footer>
