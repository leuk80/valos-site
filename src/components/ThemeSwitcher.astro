---
// Theme Switcher – Pre-launch design testing only
// Remove this component before going live.

const themes = [
  { id: 'default',          label: 'Current',       desc: 'Dark Navy (Tailwind)' },
  { id: 'pitch',            label: 'Pitch Dark',     desc: 'Brand: Rot + Teal, dunkel' },
  { id: 'pitch-light',      label: 'Pitch Light',    desc: 'Brand: Rot + Teal, hell' },
  { id: 'valos-1',          label: 'Valos 1',        desc: 'Light classic' },
  { id: 'valos-1-revos',    label: 'V1 + Animation', desc: 'Light + CSS Ringe' },
  { id: 'valos-1-revos-svg',label: 'V1 + SVG',       desc: 'Light + SVG Engine' },
];
---

<!-- Theme Switcher (Pre-launch only) -->
<div id="ts-root" aria-label="Design-Vorschau">

  <!-- Toggle Button -->
  <button id="ts-toggle" aria-expanded="false" aria-controls="ts-panel" title="Design wechseln">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
    </svg>
    <span>Design</span>
  </button>

  <!-- Panel -->
  <div id="ts-panel" role="dialog" aria-label="Theme auswählen">
    <p class="ts-heading">Vorschau</p>
    <ul class="ts-list">
      {themes.map(t => (
        <li>
          <button
            class="ts-btn"
            data-theme-id={t.id}
            title={t.desc}
          >
            <span class="ts-dot" data-dot={t.id}></span>
            <span class="ts-label">{t.label}</span>
            <span class="ts-desc">{t.desc}</span>
          </button>
        </li>
      ))}
    </ul>
    <p class="ts-note">Nur zur Pre-Launch-Ansicht</p>
  </div>

</div>

<style>
  #ts-root {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 99999;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
  }

  /* Toggle */
  #ts-toggle {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    background: rgba(10, 10, 20, 0.85);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.03em;
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  #ts-toggle:hover {
    background: rgba(20, 20, 40, 0.92);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Panel */
  #ts-panel {
    position: absolute;
    bottom: calc(100% + 10px);
    right: 0;
    width: 220px;
    background: rgba(10, 10, 20, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 14px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(20px);
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  #ts-panel.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Heading */
  .ts-heading {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin: 0 0 10px 4px;
  }

  /* List */
  .ts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  /* Button */
  .ts-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 9px 10px;
    background: transparent;
    color: rgba(255, 255, 255, 0.65);
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
  }

  .ts-btn:hover {
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.9);
  }

  .ts-btn.active {
    background: rgba(59, 126, 247, 0.18);
    border-color: rgba(59, 126, 247, 0.4);
    color: #fff;
  }

  /* Color dot */
  .ts-dot {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
  }

  .ts-dot[data-dot="default"]            { background: #070D1C; }
  .ts-dot[data-dot="pitch"]              { background: linear-gradient(135deg, #0F1D2E 50%, #E63946 50%); }
  .ts-dot[data-dot="pitch-light"]        { background: linear-gradient(135deg, #FFFFFF 50%, #E63946 50%); border-color: rgba(230,57,70,0.3); }
  .ts-dot[data-dot="valos-1"]            { background: #F8FAFC; border-color: rgba(11,31,51,0.4); }
  .ts-dot[data-dot="valos-1-revos"]      { background: linear-gradient(135deg, #F8FAFC 50%, #0A84FF 50%); }
  .ts-dot[data-dot="valos-1-revos-svg"]  { background: linear-gradient(135deg, #F8FAFC 50%, #0B1F33 50%); }

  /* Label + desc */
  .ts-label {
    font-size: 13px;
    font-weight: 500;
    flex: 1;
  }

  .ts-desc {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.3);
    white-space: nowrap;
  }

  /* Note */
  .ts-note {
    margin: 10px 4px 0;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.2);
  }
</style>

<script>
  // --- Hero HTML snippets for animation themes ---

  const HERO_CSS_ID  = 'ts-hero-css';
  const HERO_SVG_ID  = 'ts-hero-svg';
  const LINK_ATTR    = 'data-ts-theme-css';

  const heroRevosHTML = `
    <div id="${HERO_CSS_ID}" class="revenue-engine">
      <div class="engine-ring"></div>
      <div class="engine-ring-inner"></div>
      <div class="engine-core"></div>
      <div class="engine-line"></div>
      <div class="engine-line"></div>
      <div class="engine-line"></div>
      <div class="engine-line"></div>
    </div>`;

  const heroSvgHTML = `
    <div id="${HERO_SVG_ID}" class="revenue-engine-wrapper">
      <svg class="revenue-engine-svg" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
        <circle cx="400" cy="400" r="300" class="engine-ring outer" />
        <circle cx="400" cy="400" r="220" class="engine-ring middle" />
        <circle cx="400" cy="400" r="140" class="engine-ring inner" />
        <g class="engine-lines">
          <line x1="400" y1="100" x2="400" y2="400" />
          <line x1="400" y1="700" x2="400" y2="400" />
          <line x1="100" y1="400" x2="400" y2="400" />
          <line x1="700" y1="400" x2="400" y2="400" />
          <line x1="190" y1="190" x2="400" y2="400" />
          <line x1="610" y1="610" x2="400" y2="400" />
          <line x1="610" y1="190" x2="400" y2="400" />
          <line x1="190" y1="610" x2="400" y2="400" />
        </g>
        <g class="engine-nodes">
          <circle cx="400" cy="100" r="6" />
          <circle cx="400" cy="700" r="6" />
          <circle cx="100" cy="400" r="6" />
          <circle cx="700" cy="400" r="6" />
          <circle cx="190" cy="190" r="6" />
          <circle cx="610" cy="610" r="6" />
          <circle cx="610" cy="190" r="6" />
          <circle cx="190" cy="610" r="6" />
        </g>
        <circle cx="400" cy="400" r="60" class="engine-core" />
      </svg>
    </div>`;

  // --- Helpers ---

  const FONT_OUTFIT_ID = 'ts-font-outfit';

  function addLink(href: string) {
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = href;
    link.setAttribute(LINK_ATTR, '');
    document.head.appendChild(link);
  }

  function removeThemeLinks() {
    document.querySelectorAll(`link[${LINK_ATTR}]`).forEach(el => el.remove());
  }

  function removeHeroAnimations() {
    [HERO_CSS_ID, HERO_SVG_ID].forEach(id => {
      document.getElementById(id)?.remove();
    });
  }

  function injectHero(html: string) {
    removeHeroAnimations();
    const hero = document.querySelector('main > section, section');
    if (hero) {
      hero.insertAdjacentHTML('beforeend', html);
    }
  }

  function ensureOutfitFont() {
    if (!document.getElementById(FONT_OUTFIT_ID)) {
      const link = document.createElement('link');
      link.id = FONT_OUTFIT_ID;
      link.rel = 'stylesheet';
      link.href = 'https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap';
      document.head.appendChild(link);
    }
  }

  // --- Core: apply theme ---

  function applyTheme(id: string) {
    removeThemeLinks();
    removeHeroAnimations();
    document.documentElement.removeAttribute('data-theme');

    if (id === 'default') return;

    // Pitch Deck themes (from PPTX brand design)
    if (id === 'pitch') {
      ensureOutfitFont();
      document.documentElement.setAttribute('data-theme', 'pitch');
      addLink('/themes/pitch-deck.css');
      return;
    }

    if (id === 'pitch-light') {
      ensureOutfitFont();
      document.documentElement.setAttribute('data-theme', 'pitch-light');
      addLink('/themes/pitch-deck-light.css');
      return;
    }

    // All valos-1 variants share the base stylesheet + data-theme
    document.documentElement.setAttribute('data-theme', 'valos-1');
    addLink('/themes/valos-1.css');

    if (id === 'valos-1-revos') {
      addLink('/themes/valos-1-hero-revos.css');
      injectHero(heroRevosHTML);
    } else if (id === 'valos-1-revos-svg') {
      addLink('/themes/valos-1-hero-revos-svg.css');
      injectHero(heroSvgHTML);
    }
  }

  // --- UI ---

  function setTheme(id: string) {
    applyTheme(id);
    localStorage.setItem('valos-preview-theme', id);
    updateButtons(id);
  }

  function updateButtons(activeId: string) {
    document.querySelectorAll<HTMLButtonElement>('.ts-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.themeId === activeId);
    });
  }

  // --- Init ---

  const toggle  = document.getElementById('ts-toggle')!;
  const panel   = document.getElementById('ts-panel')!;

  toggle.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = panel.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!document.getElementById('ts-root')!.contains(e.target as Node)) {
      panel.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    }
  });

  document.querySelectorAll<HTMLButtonElement>('.ts-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      setTheme(btn.dataset.themeId!);
      panel.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });

  // Restore saved theme on load
  const saved = localStorage.getItem('valos-preview-theme') ?? 'default';
  applyTheme(saved);
  updateButtons(saved);
</script>
