---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Solution from '../components/Solution.astro';
import Process from '../components/Process.astro';
import WhyValos from '../components/WhyValos.astro';
import CallToAction from '../components/CallToAction.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Valos Group – Revenue Operating System"
  description="Valos Group definiert und implementiert Ihr Revenue Operating System – das Betriebssystem für nachhaltiges Umsatzwachstum. Wir verbinden und steuern die umsatzrelevanten Aktivitäten und Prozesse Ihres Unternehmens."
>
  <Header />
  <main>
    <Hero />
    <Problem />
    <Solution />
    <Process />
    <WhyValos />
    <CallToAction />
    <Contact />
  </main>
  <Footer />
</Layout>
