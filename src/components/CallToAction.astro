---
---

<section class="py-24 lg:py-32 bg-navy-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl border border-accent/15 p-12 lg:p-20">

      <!-- Background pattern -->
      <div class="absolute inset-0 cta-grid opacity-30 pointer-events-none"></div>

      <!-- Top accent line -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>

      <!-- Blue glow -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-48 bg-accent/5 blur-3xl pointer-events-none"></div>

      <div class="relative text-center">
        <div class="inline-flex items-center gap-3 mb-8">
          <div class="w-8 h-px bg-accent"></div>
          <span class="text-xs font-medium tracking-[0.25em] uppercase text-accent">Erstgespräch</span>
          <div class="w-8 h-px bg-accent"></div>
        </div>

        <h2 class="text-3xl lg:text-5xl font-bold text-white leading-[1.1] tracking-tight mb-6 max-w-3xl mx-auto">
          Lassen Sie uns Ihr<br />Revenue-System analysieren.
        </h2>

        <p class="text-slate-400 max-w-lg mx-auto mb-12 leading-relaxed text-sm lg:text-base">
          In einem unverbindlichen Erstgespräch analysieren wir Ihre aktuelle Situation
          und zeigen konkrete Hebel für planbares Wachstum.
        </p>

        <a
          href="#kontakt"
          class="inline-flex items-center gap-2 px-10 py-4 text-sm font-medium bg-accent hover:bg-accent-light text-white rounded transition-colors"
        >
          Erstgespräch vereinbaren
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 40px 40px;
  }
</style>
