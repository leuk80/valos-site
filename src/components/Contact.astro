---
---

<section id="kontakt" class="py-24 lg:py-32 bg-navy-950">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

      <!-- Left: Contact Info -->
      <div>
        <div class="inline-flex items-center gap-3 mb-6">
          <div class="w-8 h-px bg-accent"></div>
          <span class="text-xs font-medium tracking-[0.25em] uppercase text-accent">Kontakt</span>
        </div>
        <h2 class="text-3xl lg:text-4xl font-bold text-white leading-[1.1] tracking-tight mb-6">
          Gespräch<br />vereinbaren.
        </h2>
        <p class="text-slate-400 leading-relaxed mb-12 text-sm lg:text-base">
          Nehmen Sie Kontakt auf. Wir melden uns innerhalb von 24 Stunden
          für ein unverbindliches Erstgespräch.
        </p>

        <div class="space-y-6">
          <div>
            <div class="text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">E-Mail</div>
            <a
              href="mailto:info@valos.group"
              class="text-sm text-slate-300 hover:text-accent transition-colors"
            >
              info@valos.group
            </a>
          </div>
          <div>
            <div class="text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">LinkedIn</div>
            <a
              href="https://linkedin.com/company/valos-group"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-300 hover:text-accent transition-colors"
            >
              linkedin.com/company/valos-group
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div>
        <!--
          Formspree: Ersetzen Sie YOUR_FORM_ID mit Ihrer echten Formspree Form-ID.
          Account und Form-ID erstellen unter formspree.io
        -->
        <form
          id="contact-form"
          action="https://formspree.io/f/xlgwykvw"
          method="POST"
          class="space-y-5"
          novalidate
        >
          <!-- Honeypot-Feld gegen Spam (versteckt) -->
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">
                Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-navy-900 border border-white/8 rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-accent/40 transition-colors"
                placeholder="Ihr Name"
              />
            </div>
            <div>
              <label for="company" class="block text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">
                Unternehmen
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full bg-navy-900 border border-white/8 rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-accent/40 transition-colors"
                placeholder="Ihr Unternehmen"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">
              E-Mail *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-navy-900 border border-white/8 rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-accent/40 transition-colors"
              placeholder="ihre@email.com"
            />
          </div>

          <div>
            <label for="message" class="block text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">
              Nachricht
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="w-full bg-navy-900 border border-white/8 rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-accent/40 transition-colors resize-none"
              placeholder="Was beschäftigt Sie aktuell – wo sehen Sie Ihre grössten Hindernisse für planbares und nachhaltiges Umsatzwachstum?"
            ></textarea>
          </div>

          <!-- Fehlermeldung -->
          <div id="form-error" class="hidden rounded-lg border border-red-500/20 bg-red-500/5 px-4 py-3 text-sm text-red-400">
            Etwas ist schiefgelaufen. Bitte versuchen Sie es erneut oder schreiben Sie uns direkt an
            <a href="mailto:info@valos.group" class="underline hover:text-red-300">info@valos.group</a>.
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full py-4 text-sm font-medium bg-accent hover:bg-accent-light text-white rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed flex items-center justify-center gap-2"
          >
            <span id="btn-text">Nachricht senden</span>
            <svg id="btn-spinner" class="hidden animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </button>
        </form>

        <!-- Erfolgsmeldung (nach Absenden) -->
        <div id="form-success" class="hidden">
          <div class="rounded-lg border border-accent/20 bg-accent/5 px-6 py-8 text-center">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full border border-accent/30 bg-accent/10 mb-4">
              <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-white mb-2">Nachricht erhalten.</h3>
            <p class="text-sm text-slate-400">
              Vielen Dank. Wir melden uns innerhalb von 24 Stunden bei Ihnen.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    // Validierung
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Lade-State
    submitBtn.disabled = true;
    btnText?.classList.add('hidden');
    btnSpinner?.classList.remove('hidden');
    errorMsg?.classList.add('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      } else {
        throw new Error('Formspree error');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      submitBtn.disabled = false;
      btnText?.classList.remove('hidden');
      btnSpinner?.classList.add('hidden');
    }
  });
</script>
