---
const problems = [
  {
    number: '01',
    title: 'Fragmentierte Verantwortung',
    description:
      'Die Verantwortung für Umsatzgenerierung ist über verschiedene Teams und Funktionen verteilt – ohne klare Koordination oder gemeinsame Steuerung.',
  },
  {
    number: '02',
    title: 'Isolierte Massnahmen',
    description:
      'Marketing, Sales und Customer Success setzen Massnahmen unabhängig voneinander um. Synergien bleiben ungenutzt, Wirkung verpufft.',
  },
  {
    number: '03',
    title: 'Unzuverlässige Forecasts',
    description:
      'Prognosen basieren auf Intuition statt auf belastbaren Daten und Strukturen. Planungssicherheit bleibt systematisch aus.',
  },
  {
    number: '04',
    title: 'Fehlende strategische Kohärenz',
    description:
      'Abweichungen und Budgetherausforderungen werden rein taktisch beantwortet – es fehlt eine strategische Antwort auf die zentralen Fragen.',
  },
];
---

<section id="problem" class="py-24 lg:py-32 bg-navy-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <!-- Header -->
    <div class="max-w-3xl mb-16 lg:mb-20">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-8 h-px bg-accent"></div>
        <span class="text-xs font-medium tracking-[0.25em] uppercase text-accent">Das Problem</span>
      </div>
      <h2 class="text-3xl lg:text-5xl font-bold text-white leading-[1.1] tracking-tight mb-4">
        Unternehmen scheitern nicht<br class="hidden lg:block" />
        am Willen zu wachsen.
      </h2>
      <p class="text-slate-400 text-sm lg:text-base leading-relaxed">
        Sie scheitern an fehlender Systematik. Planbarer, wachsender Umsatz über Bestands- und Neukunden ist die Grundlage jedes profitablen Unternehmens. In der Realität führen verschiedene Faktoren zu Reibungsverlusten und Ineffizienzen – und zu einem Wachstum, das hinter seinem Potenzial zurückbleibt.
      </p>
    </div>

    <!-- Problem Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/5 rounded-2xl overflow-hidden">
      {problems.map((problem) => (
        <div class="bg-navy-900 p-8 lg:p-10 group hover:bg-navy-800/60 transition-colors duration-200">
          <div class="font-mono text-xs text-slate-700 mb-5 tracking-widest">{problem.number}</div>
          <h3 class="text-base font-semibold text-white mb-3">{problem.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed">{problem.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
