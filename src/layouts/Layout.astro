---
// import ThemeSwitcher from '../components/ThemeSwitcher.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Valos Group – Revenue Operating System',
  description = 'Valos Group entwickelt und implementiert das Revenue Operating System für planbares, nachhaltiges Umsatzwachstum.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de" data-theme="pitch-light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Valos Group" />
    <meta property="og:image" content="https://www.valos.group/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://www.valos.group/og-image.jpg" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/themes/pitch-deck-light.css" />
  </head>
  <body class="bg-navy-950 text-slate-100 font-sans antialiased">
    <slot />
    {/* <ThemeSwitcher /> */}
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 5rem;
  }

  * {
    box-sizing: border-box;
  }
</style>
