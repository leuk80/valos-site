---
const differentiators = [
  {
    title: 'Führungserfahrung in Revenue-Verantwortung',
    description:
      'Operative Erfahrung auf Geschäftsleitungsebene – nicht Beratung aus der Distanz. Wir kennen die Realität von Revenue-Zielen und -Druck.',
  },
  {
    title: 'Ganzheitliche Perspektive',
    description:
      'Vollständige Integration aller Revenue-Funktionen statt isolierter Optimierung einzelner Bereiche. Das System als Ganzes steht im Mittelpunkt.',
  },
  {
    title: 'Systemischer Ansatz',
    description:
      'Strukturiertes Steuerungssystem mit klaren Prozessen, KPIs und Governance – statt taktischer Einzelmassnahmen ohne strategischen Rahmen.',
  },
  {
    title: 'Fokus auf Umsetzung',
    description:
      'Implementierung in der Organisation, nicht nur Konzepte und Empfehlungen. Wir begleiten den Wandel bis zur operativen Wirksamkeit.',
  },
];

const founders = [
  { name: 'Martin Hufschmid', role: 'Partner' },
  { name: 'Kim Engels', role: 'Partner' },
  { name: 'Gregor Schröder', role: 'Partner' },
];
---

<section id="warum-valos" class="py-24 lg:py-32 bg-navy-950">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-24">

      <!-- Left: Differentiators -->
      <div class="lg:col-span-3">
        <div class="inline-flex items-center gap-3 mb-6">
          <div class="w-8 h-px bg-accent"></div>
          <span class="text-xs font-medium tracking-[0.25em] uppercase text-accent">Warum Valos</span>
        </div>
        <h2 class="text-3xl lg:text-5xl font-bold text-white leading-[1.1] tracking-tight mb-14">
          Erfahrung<br />statt Theorie.
        </h2>

        <div class="space-y-10">
          {differentiators.map((item) => (
            <div class="flex gap-6">
              <div class="w-px bg-accent/20 flex-shrink-0 mt-1"></div>
              <div>
                <h3 class="text-sm font-semibold text-white mb-2">{item.title}</h3>
                <p class="text-sm text-slate-500 leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Team -->
      <div class="lg:col-span-2">
        <div class="lg:pt-24">
          <h3 class="text-[10px] font-medium tracking-[0.25em] uppercase text-slate-600 mb-6">
            Gründer & Partner
          </h3>
          <div class="space-y-3">
            {founders.map((founder) => (
              <div class="flex items-center gap-4 p-5 rounded-xl border border-white/6 bg-navy-900/40 hover:border-white/10 transition-colors">
                <div class="w-10 h-10 rounded-lg bg-navy-800 border border-white/8 flex items-center justify-center text-slate-400 font-semibold text-sm flex-shrink-0">
                  {founder.name.charAt(0)}
                </div>
                <div>
                  <div class="text-sm font-medium text-slate-200">{founder.name}</div>
                  <div class="text-xs text-slate-600 mt-0.5">{founder.role}</div>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 p-5 rounded-xl border border-white/5 bg-navy-900/20">
            <p class="text-xs text-slate-600 leading-relaxed">
              Valos Group vereint unternehmerische Praxis mit systemischer Beratungskompetenz –
              für Unternehmen, die Wachstum planbar machen wollen.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
