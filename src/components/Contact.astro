---
---

<section id="kontakt" class="py-24 lg:py-32 bg-navy-950">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

      <!-- Left: Contact Info -->
      <div>
        <div class="inline-flex items-center gap-3 mb-6">
          <div class="w-8 h-px bg-accent"></div>
          <span class="text-xs font-medium tracking-[0.25em] uppercase text-accent">Kontakt</span>
        </div>
        <h2 class="text-3xl lg:text-4xl font-bold text-white leading-[1.1] tracking-tight mb-6">
          Gespräch<br />vereinbaren.
        </h2>
        <p class="text-slate-400 leading-relaxed mb-12 text-sm lg:text-base">
          Nehmen Sie Kontakt auf. Wir melden uns innerhalb von 24 Stunden
          für ein unverbindliches Erstgespräch.
        </p>

        <div class="space-y-6">
          <div>
            <div class="text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">E-Mail</div>
            <a
              href="mailto:info@valos.group"
              class="text-sm text-slate-300 hover:text-accent transition-colors"
            >
              info@valos.group
            </a>
          </div>
          <div>
            <div class="text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">LinkedIn</div>
            <a
              href="https://linkedin.com/company/valos-group"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-300 hover:text-accent transition-colors"
            >
              linkedin.com/company/valos-group
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div>
        <!--
          Formspree: Ersetzen Sie YOUR_FORM_ID mit Ihrer echten Formspree Form-ID.
          Kostenloser Account unter formspree.io
        -->
        <form
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="space-y-5"
          id="contact-form"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">
                Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-navy-900 border border-white/8 rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-accent/40 transition-colors"
                placeholder="Ihr Name"
              />
            </div>
            <div>
              <label for="company" class="block text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">
                Unternehmen
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full bg-navy-900 border border-white/8 rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-accent/40 transition-colors"
                placeholder="Ihr Unternehmen"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">
              E-Mail *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-navy-900 border border-white/8 rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-accent/40 transition-colors"
              placeholder="ihre@email.com"
            />
          </div>

          <div>
            <label for="message" class="block text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">
              Nachricht
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="w-full bg-navy-900 border border-white/8 rounded-lg px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-accent/40 transition-colors resize-none"
              placeholder="Was beschäftigt Sie aktuell – und wo sehen Sie die grössten Wachstumshebel?"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-4 text-sm font-medium bg-accent hover:bg-accent-light text-white rounded-lg transition-colors"
          >
            Nachricht senden
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
