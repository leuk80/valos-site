---
const pillars = [
  'Strategie, Prozesse und Technologie auf ein Ziel ausrichtet',
  'Gemeinsame KPIs für alle Revenue-Funktionen definiert',
  'Marketing, Sales, Produkt und Customer Success synchronisiert',
  'Planbare Umsatzsteuerung systemisch ermöglicht',
];
---

<section id="revos" class="py-24 lg:py-32 bg-navy-950">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Left: Content -->
      <div>
        <div class="inline-flex items-center gap-3 mb-6">
          <div class="w-8 h-px bg-accent"></div>
          <span class="text-xs font-medium tracking-[0.25em] uppercase text-accent">Die Lösung</span>
        </div>
        <h2 class="text-3xl lg:text-5xl font-bold text-white leading-[1.1] tracking-tight mb-6">
          Das Revenue<br />Operating System.
        </h2>
        <p class="text-slate-400 leading-relaxed mb-10 text-sm lg:text-base">
          Ein integriertes Steuerungssystem, das die gesamte Revenue-Organisation auf
          ein gemeinsames Ziel ausrichtet – messbar, skalierbar und nachhaltig implementiert.
        </p>
        <ul class="space-y-4">
          {pillars.map((pillar) => (
            <li class="flex items-start gap-4">
              <div class="mt-1 w-5 h-5 rounded bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-sm text-slate-300 leading-relaxed">{pillar}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: System Diagram -->
      <div class="flex items-center justify-center">
        <div class="w-full max-w-md border border-white/8 rounded-2xl overflow-hidden bg-navy-900/50">

          <!-- Diagram Header -->
          <div class="px-6 py-5 border-b border-white/8 flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-accent"></div>
            <span class="text-sm font-semibold text-white tracking-wide">Revenue Operating System</span>
          </div>

          <div class="p-6 space-y-3">

            <!-- Functions Row -->
            <div>
              <div class="text-[10px] font-medium tracking-[0.2em] uppercase text-slate-600 mb-2">Revenue-Funktionen</div>
              <div class="grid grid-cols-4 gap-2">
                {['Marketing', 'Sales', 'Produkt', 'CS'].map((fn) => (
                  <div class="text-center py-3 px-1 bg-navy-800/60 rounded-lg border border-white/5">
                    <div class="text-xs text-slate-400 font-medium">{fn}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Divider with arrow -->
            <div class="flex items-center justify-center py-1">
              <svg class="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
              </svg>
            </div>

            <!-- System Layers -->
            <div class="space-y-2">
              <div class="flex items-center gap-3 py-3 px-4 bg-accent/8 rounded-lg border border-accent/15">
                <div class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></div>
                <div class="text-xs text-accent font-medium">Gemeinsame KPIs & Governance</div>
              </div>
              <div class="flex items-center gap-3 py-3 px-4 bg-navy-800/40 rounded-lg border border-white/5">
                <div class="w-1.5 h-1.5 rounded-full bg-slate-600 flex-shrink-0"></div>
                <div class="text-xs text-slate-400">Integrierte Prozesse & Playbooks</div>
              </div>
              <div class="flex items-center gap-3 py-3 px-4 bg-navy-800/40 rounded-lg border border-white/5">
                <div class="w-1.5 h-1.5 rounded-full bg-slate-600 flex-shrink-0"></div>
                <div class="text-xs text-slate-400">Technologie & Datenarchitektur</div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>
